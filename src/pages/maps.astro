---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Maps, Location & Cartographers" description="Maps, location, and cartography of Peru.">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-amber-600 to-amber-800 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-amber-200 uppercase tracking-widest text-sm mb-2">Earth Processes · Week 1</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Maps, Location & Cartographers</h1>
      <p class="text-amber-100 text-lg">Understanding Peru's place on Earth through the science of mapping.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-16">

    <!-- Coming soon placeholder -->
    <div class="bg-white rounded-2xl border border-dashed border-amber-300 p-12 text-center shadow-sm">
      <div class="text-5xl mb-4"></div>
      <h2 class="text-2xl font-bold text-stone-700 mb-2">Content Coming Soon</h2>
      <p class="text-stone-500 mb-6 max-w-md mx-auto">
        This page will cover Peru's geographic coordinates, regional maps, satellite imagery, and the history of cartography in South America.
      </p>
      <div class="grid sm:grid-cols-3 gap-4 text-left max-w-2xl mx-auto">
        {[
          { icon: "", title: "Location & Coordinates", desc: "Latitude, longitude, hemispheres, and borders" },
          { icon: "", title: "Satellite Imagery", desc: "NASA and Google Earth views of Peru's terrain" },
          { icon: "", title: "Cartographers", desc: "History of mapping Peru from colonial era to today" },
        ].map(item => (
          <div class="bg-amber-50 rounded-xl p-4">
            <div class="text-2xl mb-1">{item.icon}</div>
            <h3 class="font-semibold text-stone-700 text-sm mb-1">{item.title}</h3>
            <p class="text-stone-500 text-xs">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</Layout>
