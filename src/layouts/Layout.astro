---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "An earth science exploration of Peru" } = Astro.props;
const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}`, label: "Home" },
  { href: `${base}about`, label: "About" },
];
const earthLinks = [
  { href: `${base}maps`, label: "Maps & Location" },
  { href: `${base}plate-tectonics`, label: "Plate Tectonics" },
  { href: `${base}weathering`, label: "Weathering & Erosion" },
  { href: `${base}fluvial`, label: "Fluvial & Coastlines" },
  { href: `${base}climate`, label: "Climate & Biomes" },
];
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Peru Earth Science</title>
    <style>
      .dropdown:hover .dropdown-menu { display: block; }
    </style>
  </head>
  <body class="bg-stone-50 text-stone-800 min-h-screen flex flex-col">

    <!-- Navbar -->
    <header class="bg-red-700 shadow-lg sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href={base} class="text-white font-bold text-lg tracking-wide">
            Peru Earth Science
          </a>

          <!-- Nav links -->
          <nav class="flex items-center gap-1 text-sm font-medium">
            {navLinks.map(link => (
              <a
                href={link.href}
                class={`px-3 py-2 rounded transition-colors ${
                  currentPath === link.href || currentPath === link.href + '/'
                    ? "bg-white text-red-700"
                    : "text-white hover:bg-red-600"
                }`}
              >
                {link.label}
              </a>
            ))}

            <!-- Earth Processes dropdown -->
            <div class="dropdown relative">
              <button class={`px-3 py-2 rounded transition-colors flex items-center gap-1 ${
                earthLinks.some(l => currentPath.includes(l.href))
                  ? "bg-white text-red-700"
                  : "text-white hover:bg-red-600"
              }`}>
                Earth Processes
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="dropdown-menu hidden absolute top-full left-0 mt-1 bg-white rounded-lg shadow-xl border border-stone-200 w-52 py-1 z-50">
                {earthLinks.map(link => (
                  <a
                    href={link.href}
                    class={`block px-4 py-2 text-sm transition-colors ${
                      currentPath.includes(link.href)
                        ? "bg-red-50 text-red-700 font-semibold"
                        : "text-stone-700 hover:bg-stone-50"
                    }`}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>

            <a
              href={`${base}references`}
              class={`px-3 py-2 rounded transition-colors ${
                currentPath.includes('references')
                  ? "bg-white text-red-700"
                  : "text-white hover:bg-red-600"
              }`}
            >
              References
            </a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-stone-800 text-stone-400 text-sm py-4 mt-12">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <p>Peru Earth Science · Ensign College · 2026</p>
      </div>
    </footer>
  </body>
</html>
